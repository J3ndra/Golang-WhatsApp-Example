# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Cloud API Configuration  (all three are REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────

# Token you set in the Meta App Dashboard under Webhooks → Verify Token.
WHATSAPP_VERIFY_TOKEN=your_verify_token

# Numeric Phone Number ID from Meta Business Suite → WhatsApp → Configuration.
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Permanent System User Token (or temporary user access token for testing).
# Never commit the real value — use a secrets manager in production.
WHATSAPP_ACCESS_TOKEN=your_access_token

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration  (all optional — defaults shown)
# ─────────────────────────────────────────────────────────────────────────────

# TCP port the HTTP server listens on.
PORT=8080

# Path to the SQLite database file.
DB_PATH=kiw.db

# ─────────────────────────────────────────────────────────────────────────────
# Graph API Configuration  (optional — defaults shown)
# ─────────────────────────────────────────────────────────────────────────────

GRAPH_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0

# ─────────────────────────────────────────────────────────────────────────────
# WebSocket
# ─────────────────────────────────────────────────────────────────────────────
# No additional env vars required.
# The CS dashboard connects to:  ws://<host>:<PORT>/ws
# In production behind TLS use:  wss://<host>/ws
